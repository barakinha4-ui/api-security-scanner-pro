# API Security Scanner Pro — Configuration
# ──────────────────────────────────────────

# 🔑 Dashboard Access Key
# This is the key you use to log into the real-time dashboard.
# If empty, a random key will be generated at startup.
SCANNER_API_KEY=Gustavo222@2

# 🔐 Data Encryption Master Key (AES-256)
# IMPORTANT: Keep this safe! Without it, you cannot decrypt encrypted reports (.json).
# DO NOT change this if you have already encrypted data you wish to keep.
SCANNER_ENCRYPTION_KEY=josenairjosiirenegustavo51568161

# 🌐 Environment
# Host and port for the API server
SCANNER_HOST=0.0.0.0
SCANNER_PORT=8000

# ⚙️ Scanner Defaults
MAX_CONCURRENCY=20
REQUEST_TIMEOUT=10
OAST_PROVIDER=interact.sh
