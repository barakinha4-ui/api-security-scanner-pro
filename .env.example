# Configurações do Engine
MAX_CONCURRENCY=20
REQUEST_TIMEOUT=10
ENABLE_OAST=true
OAST_PROVIDER=interact.sh

# Chave API / Shield
SCANNER_API_KEY=sua_chave_segura_aqui
API_KEY=sua_chave_segura_aqui
API_KEY_REQUIRED=true

# Rate Limits e Proteção (Shield)
ALLOW_PRIVATE_TARGETS=false
RATE_LIMIT_PER_MINUTE=1000

# Configurações de Banco/Logs se houver
LOG_LEVEL=INFO

# SaaS Wrapper / API Autenticação (app.py)
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_JWT_SECRET=super-secret-jwt-token-from-supabase
API_KEY_SECRET=super-secret-local-key
