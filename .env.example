# ===========================================
# SaaS Scanner Pro — Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores.

# ── Autenticação ──────────────────────────
# Chave de API para autenticação local (Bearer Token)
API_KEY_SECRET=troque-para-uma-chave-forte-aqui

# Chave JWT do Supabase (para autenticação em produção)
SUPABASE_JWT_SECRET=supabase-secret

# ── Scanner ───────────────────────────────
# Mesma chave usada pelo módulo scanner original
SCANNER_API_KEY=troque-para-uma-chave-forte-aqui
SCANNER_ENCRYPTION_KEY=chave-aes-256-de-exatamente-32-chars

# Timeout do scan em segundos (padrão: 300 = 5 minutos)
SCAN_TIMEOUT=300

# Concorrência máxima de requests por scan
MAX_CONCURRENCY=20

# ── Servidor ──────────────────────────────
SCANNER_HOST=0.0.0.0
SCANNER_PORT=8000

# Ambiente: "development" (habilita /docs) ou "production"
ENV=development

# Origens permitidas pelo CORS (separe por vírgula, ou * para tudo)
ALLOWED_ORIGINS=*

# ── Redis ─────────────────────────────────
# Host do Redis (use "redis" para Docker Compose, "localhost" para dev local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Deixe vazio se não tiver senha
REDIS_PASSWORD=

# TTL em segundos para jobs completados/falhos (padrão: 3600 = 1 hora)
JOB_TTL=3600

# ── Outros ───────────────────────────────
REQUEST_TIMEOUT=10
OAST_PROVIDER=interact.sh
