# ================================================================
# API Security Scanner Pro — Environment Variables
# ================================================================
# IMPORTANT: NEVER commit .env to version control.
#            Set these variables in Railway Dashboard.
# ================================================================

# ─── Auth ───────────────────────────────────────────────────────
# IMPORTANTE: Gere seus próprios valores usando:
# SCANNER_API_KEY=$(python -c "import secrets; print(secrets.token_hex(16))")
# API_KEY_SECRET=$(python -c "import secrets; print(secrets.token_hex(32))")
SCANNER_API_KEY=CHANGE_ME_USE_SECRETS_TOKEN_HEX_16
API_KEY_SECRET=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32

# ─── Encryption ─────────────────────────────────────────────────
# Gere usando: python -c "import secrets; print(secrets.token_urlsafe(24))"
SCANNER_ENCRYPTION_KEY=CHANGE_ME_USE_SECRETS_TOKEN_URLSAFE

# ─── Server ─────────────────────────────────────────────────────
SCANNER_HOST=0.0.0.0
SCANNER_PORT=8000

# ─── Scanner Defaults ───────────────────────────────────────────
MAX_CONCURRENCY=20
REQUEST_TIMEOUT=10
OAST_PROVIDER=interact.sh

# ─── Supabase Auth ──────────────────────────────────────────────
# Obtenha estas credenciais no dashboard do Supabase:
# 1. SUPABASE_URL: Settings > API > Project URL
# 2. SUPABASE_KEY: Settings > API > anon public key
# 3. SUPABASE_JWT_SECRET: Settings > API > JWT Secret
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ...
SUPABASE_JWT_SECRET=CHANGE_ME_JWT_SECRET_BASE64

# ─── Supabase PostgreSQL ───────────────────────────────────────
# Obtenha em: Settings > Database > Connection String
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@host:6543/postgres

# ─── Redis (Railway) ───────────────────────────────────────────
# Adicione Redis no Railway e use o REDIS_URL gerado automaticamente
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Celery ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Security ──────────────────────────────────────────────────
ALLOW_PRIVATE_TARGETS=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Railway Production URLs ───────────────────────────────────
# Atualize quando fizer deploy no Railway:
# ALLOWED_ORIGINS=https://seu-app.railway.app,https://seu-dashboard.railway.app
